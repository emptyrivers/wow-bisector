<Ui
  xmlns="http://www.blizzard.com/wow/ui/"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ./Bisector.xsd"
>
  <Include file="ControlPanel.lua"/>
  <Frame
    name="BisectorControlPanelTemplate"
    mixin="BisectorControlPanelMixin"
    inherits="DefaultPanelTemplate"
    toplevel="true"
    enableMouse="true"
    clampedToScreen="true"
    movable="true"
    frameStrata="DIALOG"
    virtual="true"
    hidden="true"
  >
    <Anchors>
      <Anchor point="TOPLEFT" x="300" y="-200"/>
    </Anchors>
    <Size x="240" y="210"/>
    <Scripts>
      <OnLoad method="OnLoad"/>
      <OnShow method="OnShow"/>
      <OnMouseDown method="OnMouseDown"/>
      <OnMouseUp method="OnMouseUp"/>
    </Scripts>
    <Frames>
      <Button
        parentKey="CloseButton"
        inherits="UIPanelCloseButtonDefaultAnchors"
      />
      <Button
        parentKey="StartButton"
        inherits="UIPanelButtonTemplate"
        text="Start"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="14" y="-68"/>
        </Anchors>
        <Size x="101" y="22"/>
        <Scripts>
          <OnClick>self:GetParent():OnStartClicked()</OnClick>
        </Scripts>
      </Button>
      <Button
        parentKey="ResetButton"
        inherits="UIPanelButtonTemplate"
        text="Reset"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="122" y="-68"/>
        </Anchors>
        <Size x="107" y="22"/>
        <Scripts>
          <OnClick>self:GetParent():OnResetClicked()</OnClick>
        </Scripts>
      </Button>
      <Button
        parentKey="GoodButton"
        inherits="UIPanelButtonTemplate"
        text="Good"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="14" y="-93"/>
        </Anchors>
        <Size x="101" y="22"/>
        <Scripts>
          <OnClick>self:GetParent():OnGoodClicked()</OnClick>
        </Scripts>
      </Button>
      <Button
        parentKey="BadButton"
        inherits="UIPanelButtonTemplate"
        text="Bad"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="122" y="-93"/>
        </Anchors>
        <Size x="107" y="22"/>
        <Scripts>
          <OnClick>self:GetParent():OnBadClicked()</OnClick>
        </Scripts>
      </Button>
      <Button
        parentKey="ContinueButton"
        inherits="UIPanelButtonTemplate"
        text="Continue"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="14" y="-118"/>
        </Anchors>
        <Size x="101" y="22"/>
        <Scripts>
          <OnClick>self:GetParent():OnContinueClicked()</OnClick>
        </Scripts>
      </Button>
      <Button
        parentKey="PrintButton"
        inherits="UIPanelButtonTemplate"
        text="Print"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="122" y="-118"/>
        </Anchors>
        <Size x="107" y="22"/>
        <Scripts>
          <OnClick>self:GetParent():OnPrintClicked()</OnClick>
        </Scripts>
      </Button>
      <EditBox
        parentKey="HintInput"
        inherits="InputBoxTemplate"
        autoFocus="false"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="42" y="-152"/>
        </Anchors>
        <Size x="140" y="20"/>
      </EditBox>
      <Button
        parentKey="HintButton"
        inherits="UIPanelButtonTemplate"
        text="Apply"
      >
        <Anchors>
          <Anchor point="TOPLEFT" x="186" y="-150"/>
        </Anchors>
        <Size x="46" y="20"/>
        <Scripts>
          <OnClick>self:GetParent():OnHintClicked()</OnClick>
        </Scripts>
      </Button>
    </Frames>
    <Layers>
      <Layer>
        <FontString
          parentKey="StatusText"
          inherits="GameFontNormal"
        >
          <Anchors>
            <Anchor point="TOPLEFT" x="10" y="-28"/>
          </Anchors>
          <Size x="220" y="0"/>
        </FontString>
        <FontString
          parentKey="StepText"
          inherits="GameFontNormalSmall"
        >
          <Anchors>
            <Anchor point="TOPLEFT" x="10" y="-44"/>
          </Anchors>
          <Size x="220" y="0"/>
        </FontString>
        <FontString
          parentKey="HintLabel"
          inherits="GameFontNormalSmall"
          text="Hint:"
        >
          <Anchors>
            <Anchor point="TOPLEFT" x="10" y="-148"/>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
  </Frame>
</Ui>
